<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tía Caro</title>

    <link rel="icon" type="image/png" href="~/img/logo.png">

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Montserrat:wght@300;400;600&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body style="display: flex; flex-direction: column; min-height: 100vh;">
    
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom py-3">
            <div class="container-fluid px-5">
                
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/img/logo.png" alt="Tía Caro Logo" style="height: 45px; width: auto;">
                </a>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav text-uppercase" style="font-size: 0.75rem; letter-spacing: 2px; font-weight: 600;">
                        <li class="nav-item"><a class="nav-link text-dark px-3" asp-controller="Home" asp-action="Index">Inicio</a></li>
                        <li class="nav-item"><a class="nav-link text-dark px-3" asp-controller="Catalogo" asp-action="Index">Menú</a></li>
                        <li class="nav-item"><a class="nav-link text-dark px-3" asp-controller="Info" asp-action="Ubicacion">Ubicación</a></li>
                        <li class="nav-item"><a class="nav-link text-dark px-3" asp-controller="Nosotros" asp-action="Index">Quienes somos</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" style="flex: 1;">
        @RenderBody()
    </main>

    <footer class="main-footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4 mb-md-0">
                    <h5 class="footer-title">TÍA CARO</h5>
                    <p class="footer-text">Tradición yucateca en San Pedro Uxmal.</p>
                </div>

                <div class="col-md-4 text-md-center mb-4 mb-md-0">
                    <h5 class="footer-title">EXPLORA</h5>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Catalogo" asp-action="Index" class="footer-link">Menú</a></li>
                        <li><a asp-controller="Info" asp-action="Ubicacion" class="footer-link">Ubicación</a></li>
                    </ul>
                </div>

                <div class="col-md-4 text-md-end">
                    <h5 class="footer-title">REDES</h5>
                    <div class="footer-socials">

                        <a href="https://www.tiktok.com/@@antojitos_latiacaro" target="_blank" rel="noopener noreferrer">
                            <i class="bi bi-tiktok"></i>
                        </a>
                        <a href="https://www.facebook.com/people/Antojitos-LA-T%C3%ADA-CARO/100057718524240/" target="_blank" rel="noopener noreferrer">
                            <i class="bi bi-facebook"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>