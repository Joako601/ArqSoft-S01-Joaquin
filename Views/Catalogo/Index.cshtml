@model IEnumerable<Catalogo.Models.Item>

@{
    ViewData["Title"] = "Menú - Tía Caro";
}

@section Styles {
    <link rel="stylesheet" href="~/css/menu.css" asp-append-version="true" />
}

<div class="container py-5 mt-3">
    <div class="text-center mb-5 fade-in-up">
        <h1 style="font-family: 'Playfair Display', serif; color: #222; font-weight: 700; font-size: 4.5rem; margin-bottom: 0.1rem;">
            Antojitos Tía Caro
        </h1>
        
        <div class="mx-auto my-4" style="width: 80px; height: 3px; background-color: #b5a478;"></div>

        <p class="mt-4">
            <a href="#" class="text-decoration-none text-uppercase" style="color: #b5a478; font-size: 0.75rem; letter-spacing: 2px; font-weight: 600;">
                + Integrar Nuevo Platillo
            </a>
        </p>
    </div>

    <div class="menu-filters text-center mb-5 fade-in-up" style="animation-delay: 0.2s;">
        <button class="filter-btn active" data-filter="todos">Todos</button>
        <button class="filter-btn" data-filter="panuchos">Panuchos</button>
        <button class="filter-btn" data-filter="salbutes">Salbutes</button>
        <button class="filter-btn" data-filter="tortas">Tortas</button>
        <button class="filter-btn" data-filter="caldos">Caldos</button>
        <button class="filter-btn" data-filter="bebidas">Bebidas</button>
    </div>

    <div class="row justify-content-center" id="menu-container">
        @if (Model != null && Model.Any())
        {
            int delay = 1;
            foreach (var item in Model)
            {
                <div class="col-md-9 mb-4 menu-item-card card-animate" data-category="@item.Categoria.ToLower()" style="animation-delay: @(delay * 0.1)s">
                    
                    <div class="card border-0 p-5 item-card" style="background-color: #ffffff; box-shadow: 0 10px 30px rgba(0,0,0,0.03); border-radius: 2px;">
                        <div class="d-flex flex-column flex-md-row justify-content-between">
                            
                            <div>
                                <h2 style="font-family: 'Playfair Display', serif; color: #222; font-weight: 700; font-size: 2.2rem; margin-bottom: 0.5rem;">
                                    @item.Platillo
                                </h2>
                                <p class="text-muted mb-5" style="font-family: 'Inter', sans-serif; font-size: 0.95rem;">
                                    @item.Descripcion
                                </p>
                                <span class="text-uppercase" style="color: #b5a478; font-size: 0.7rem; letter-spacing: 2px; font-weight: 600;">
                                    Base: @item.Base — @item.Categoria
                                </span>
                            </div>

                            <div class="text-md-end d-flex flex-column justify-content-between align-items-md-end mt-4 mt-md-0">
                                <h3 style="color: #b5a478; font-weight: 400; font-size: 1.4rem;">
                                    $@item.Precio
                                </h3>
                                <a asp-controller="Catalogo" asp-action="Detalle" asp-route-id="@item.Id"
                                       class="ver-experiencia-link text-dark text-uppercase text-decoration-none">
                                    Ver Experiencia &rarr;
                                </a>
                            </div>

                        </div>
                    </div>

                </div>
                delay++;
            }
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/filtrosMenu.js" asp-append-version="true"></script>
}