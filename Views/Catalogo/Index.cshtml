@model IEnumerable<Catalogo.Models.Item>

@{
    ViewData["Title"] = "Menú";
}

@section Styles {
    <link rel="stylesheet" href="~/css/menu.css" asp-append-version="true" />
}

<div class="container py-5">
    <header class="text-center mb-5 module-reveal">
        <h1 class="display-2 mb-2" style="font-family: 'Playfair Display', serif; font-style: italic;">
            Antojitos <span style="font-style: normal; font-weight: 200;">Tía Caro</span>
        </h1>
        <p class="text-uppercase small tracking-widest text-muted" style="letter-spacing: 0.3rem;">San Pedro Uxmal • Mérida</p>
        
        <div class="mt-4">
            <a asp-action="Agregar" class="btn-add-platillo">
                <i class="bi bi-plus-lg"></i> Integrar nuevo platillo
            </a>
        </div>
    </header>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            @foreach (var platillo in Model)
            {
                <article class="item-module module-reveal">
                    <div class="item-header">
                        <h3 class="item-title">@platillo.Platillo</h3>
                        <span class="item-price">$@platillo.Precio</span>
                    </div>
                    <p class="item-description">@platillo.Descripcion</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <div class="item-meta">
                            BASE: @platillo.Ingredientes — @platillo.Categoria
                        </div>
                        <a asp-action="Detalle" asp-route-id="@platillo.Id" class="btn-ver-experiencia">
                            Ver Experiencia <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </article>
            }
        </div>
    </div>
</div>